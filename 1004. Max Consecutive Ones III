class Solution {
    public int longestOnes(int[] nums, int k) {
        int left = 0, zcnt = 0, mx = 0;
        
        for (int right = 0; right < nums.length; right++) {
            if (nums[right] == 0) {
                zcnt++;
            }
            
            while (zcnt > k) {
                if (nums[left] == 0) {
                    zcnt--;
                }
                left++;
            }
            
            mx = Math.max(mx, right - left + 1);
        }
        
        return mx;
    }
}
