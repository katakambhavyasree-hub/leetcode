class Solution {
    public void sortColors(int[] nums) {
        int rcnt=0,bcnt=0,wcnt=0;
        for(int i=0;i<nums.length;i++){
            if(nums[i]==0){
                rcnt++;

            }else if(nums[i]==1){
                wcnt++;
            }else{
                bcnt++;
            }}
            int idx=0;
            for(int i=0; i<rcnt; i++){
                nums[idx]=0;
                idx++;
            }
            for(int i=0;i<wcnt;i++){
                nums[idx]=1;
                idx++;
            }
            for(int i=0;i<bcnt;i++){
                nums[idx]=2;
                idx++;
            }
        }
    }
 
